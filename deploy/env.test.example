# Copy to /opt/cardline/.env on the test server.

POSTGRES_PASSWORD=change-me

NODE_ENV=staging
PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_USER=cardline
DB_PASSWORD=change-me-same-as-POSTGRES_PASSWORD
DB_NAME=cardline_test

JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars

AUTH_LINK_BASE_URL=https://api-test.cardline.io
AUTH_MAGICLINK_TTL_MIN=30
AUTH_REFRESH_TTL_DAYS=30

GOOGLE_CLIENT_ID=1029116199508-0evr4juf6ldt32btso6kp3ducqpeig3u.apps.googleusercontent.com
CATALOG_PUBLIC_KEY=cardline-public-catalog-key

# Transactional email (Resend — https://resend.com)
# Requires verified cardline.io domain in Resend before production use.
RESEND_API_KEY=
MAIL_FROM=Cardline <noreply@cardline.io>

APPLE_IAP_BUNDLE_ID=io.cardline.app
APPLE_IAP_ENVIRONMENT=Sandbox
APPLE_APP_ID=
APPLE_ROOT_CA_PATHS=certs/AppleRootCA-G3.cer,certs/AppleIncRootCertificate.cer

APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=App.Cardline
APNS_PRIVATE_KEY_PATH=keys/AuthKey_XXXXX.p8

ENABLE_NOTIFICATION_DEV=true

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=cardline-test-assets
S3_REGION=fsn1
