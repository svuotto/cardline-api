# Copy to `.env` for local development. Never commit `.env`.

NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=cardline
DB_PASSWORD=change-me
DB_NAME=cardline_test

# JWT (use: openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars

# Public URLs (magic links, auth callbacks)
AUTH_LINK_BASE_URL=http://localhost:3000

# Auth session
AUTH_MAGICLINK_TTL_MIN=30
AUTH_REFRESH_TTL_DAYS=30

# Google Sign-In (iOS client ID)
GOOGLE_CLIENT_ID=

# Transactional email (Resend — https://resend.com)
RESEND_API_KEY=
MAIL_FROM=Cardline <noreply@cardline.io>

# Catalog API protection (must match iOS Info.plist CATALOG_PUBLIC_KEY)
CATALOG_PUBLIC_KEY=cardline-public-catalog-key

# Apple In-App Purchases / subscriptions
APPLE_IAP_BUNDLE_ID=io.cardline.app
APPLE_IAP_ENVIRONMENT=Sandbox
APPLE_APP_ID=
APPLE_ROOT_CA_PATHS=certs/AppleRootCA-G3.cer,certs/AppleIncRootCertificate.cer

# Apple Push Notifications (path relative to project root on server)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=App.Cardline
APNS_PRIVATE_KEY_PATH=keys/AuthKey_XXXXX.p8

# Apple Server API (subscription replay, optional)
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_PRIVATE_KEY=

# Notifications (test server: keep dev helpers enabled)
ENABLE_NOTIFICATION_DEV=true

# Optional: Hetzner Object Storage (test/prod server)
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=cardline-test-assets
# S3_REGION=fsn1
